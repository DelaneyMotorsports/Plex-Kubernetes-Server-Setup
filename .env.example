# ============================================================
# Media Stack — Kubernetes Secret & Config Template
# Copy to .env, fill in your values, then run:
#   ./scripts/create-secrets.sh
# NEVER commit the .env file (it is in .gitignore)
# ============================================================

# ---- Timezone & User IDs ----
TZ=America/New_York           # Your timezone: timedatectl list-timezones
PUID=1000                     # Your UID: run `id -u`
PGID=1000                     # Your GID: run `id -g`

# ---- VPN — NordVPN WireGuard (Gluetun) ----
VPN_SERVICE_PROVIDER=nordvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=CHANGE-ME        # From: nordvpn meshnet or NordVPN app → Generate key
WIREGUARD_ADDRESSES=CHANGE-ME/32       # e.g. 10.5.0.2/32 (from NordVPN WireGuard config)
SERVER_REGIONS=Europe                  # https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
SERVER_CATEGORIES=P2P                  # "P2P" for torrent-optimized servers
UPDATER_PERIOD=24h
UPDATER_VPN_SERVICE_PROVIDERS=nordvpn

# ---- Plex ----
# Get a 4-minute claim token at: https://plex.tv/claim
# Apply within 4 minutes of first pod start. Remove after initial claim.
PLEX_CLAIM=CHANGE-ME

# ---- qBittorrent ----
WEBUI_PORT=8080

# ---- Flaresolverr ----
LOG_LEVEL=info
LOG_HTML=false
CAPTCHA_SOLVER=none

# ---- Storage paths (used by scripts, not directly by K8s) ----
# These should match the paths in k8s/base/storage/media-pv.yaml
MEDIA_HOST_PATH=/mnt/media
DOWNLOADS_HOST_PATH=/mnt/downloads
